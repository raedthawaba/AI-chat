# --- خادم Gemini API Proxy ---
# مفتاح API الخاص بـ Google Gemini (مطلوب)
GEMINI_API_KEY=your_api_key_here

# منفذ السيرفر (افتراضي 3000)
PORT=3000

# بيئة التشغيل (development أو production)
NODE_ENV=development

# --- إعدادات الأمان (Rate Limiting) ---
# عدد الطلبات المسموح بها في النافذة الزمنية
RATE_LIMIT_MAX=100
# النافذة الزمنية بالدقائق
RATE_LIMIT_WINDOW_MINS=15

# --- إعدادات الواجهة الأمامية (Vite) ---
# ملاحظة: يجب أن تبدأ المتغيرات بـ VITE_ لتكون متاحة في الواجهة الأمامية
VITE_APP_TITLE=AI Chat Pro
VITE_API_BASE_URL=/api

# --- نظام التسجيل (Logging System - Phase 9.3) ---
# المستوى الأدنى للسجلات: debug | info | warn | error
# الافتراضي: debug في التطوير، info في الإنتاج
LOG_LEVEL=info

# تفعيل الكتابة إلى ملفات في مجلد logs/
# الافتراضي: true في الإنتاج، false في التطوير
LOG_TO_FILE=true

# مسار مجلد الملفات (نسبي إلى جذر المشروع)
LOG_DIR=logs

# --- نظام التحليلات (Analytics - Phase 9.4) ---
# تفعيل تتبّع الأحداث (page_view, chat_sent, chat_received, ...)
ANALYTICS_ENABLED=true

# حفظ الأحداث في ملفات يومية (analytics-YYYY-MM-DD.jsonl)
ANALYTICS_TO_FILE=true

# مجلد حفظ ملفات الأحداث
ANALYTICS_DIR=logs
